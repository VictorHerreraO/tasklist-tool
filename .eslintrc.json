{
    "root": true,
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": 2020,
        "sourceType": "module"
    },
    "plugins": [
        "@typescript-eslint"
    ],
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
    ],
    "rules": {
        "@typescript-eslint/naming-convention": [
            "error",
            {
                "selector": "variable",
                "format": [
                    "camelCase",
                    "UPPER_CASE"
                ]
            }
        ],
        "semi": "error",
        "curly": "error",
        "no-unused-vars": "off",
        "@typescript-eslint/no-unused-vars": "warn"
    },
    "ignorePatterns": [
        "out",
        "node_modules",
        ".vscode-test"
    ]
}